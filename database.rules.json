{
    "rules": {
        "users": {
            ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
            ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
            "$uid": {
                ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
                ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
                "name": {
                    ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
                },
                "email": {
                    ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (!data.parent().exists() && auth.uid === $uid))",
                    ".validate": "newData.isString()"
                },
                "subscription": {
                    ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (!data.parent().exists() && auth.uid === $uid))",
                    ".validate": "newData.isString() && (newData.val() === 'free' || newData.val() === 'pro' || newData.val() === 'enterprise')"
                },
                "maxInterviews": {
                    ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (!data.parent().exists() && auth.uid === $uid))",
                    ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"
                },
                "interviewsCount": {
                    ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
                    ".validate": "newData.isNumber() && newData.val() >= 0 && (root.child('users').child(auth.uid).child('isAdmin').val() === true || !data.exists() || newData.val() >= data.val())"
                },
                "isAdmin": {
                    ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
                    ".validate": "newData.isBoolean()"
                },
                "deleted": {
                    ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
                    ".validate": "newData.isBoolean()"
                },
                "deletedAt": {
                    ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
                    ".validate": "newData.isNumber()"
                },
                "lastUpgradedAt": {
                    ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true"
                },
                "photoURL": {
                    ".write": "auth != null && auth.uid === $uid",
                    ".validate": "newData.isString() && newData.val().length <= 500"
                },
                "preferences": {
                    ".write": "auth != null && auth.uid === $uid",
                    "duration": {
                        ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 120"
                    },
                    "language": {
                        ".validate": "newData.isString() && (newData.val() === 'English' || newData.val() === 'Hindi' || newData.val() === 'Hinglish')"
                    }
                },
                "history": {
                    "$sessionId": {
                        ".write": "auth != null && auth.uid === $uid",
                        ".read": "auth != null && auth.uid === $uid",
                        "id": {
                            ".validate": "newData.isString()"
                        },
                        "userId": {
                            ".validate": "newData.isString() && newData.val() === auth.uid"
                        },
                        "startTime": {
                            ".validate": "newData.isNumber()"
                        },
                        "date": {
                            ".validate": "newData.isString()"
                        },
                        "overallScore": {
                            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 100)"
                        }
                    }
                }
            }
        },
        "processedPayments": {
            ".read": false,
            ".write": false
        },
        "$other": {
            ".read": false,
            ".write": false
        }
    }
}